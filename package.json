{
  "name": "vnova-engine",
  "version": "0.3.0",
  "description": "Vue 3 visual novel framework — script-first, Vite-native",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/vnova.d.ts",
  "exports": {
    ".": {
      "types": "./src/vnova.d.ts",
      "default": "./src/index.js"
    },
    "./vite-plugin": "./vite-plugin/index.js",
    "./style.css": "./src/vnova.css"
  },
  "files": [
    "src",
    "vite-plugin"
  ],
  "scripts": {
    "dev": "vite",
    "build:lib": "vite build --config vite.lib.config.js",
    "prebuild:demo": "node scripts/copy-assets.js",
    "build:demo": "vite build --config vite.demo.config.js",
    "preview:demo": "vite preview --config vite.demo.config.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "pinia": "^3.0.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "pinia": "^3.0.0",
    "vite": "^5.0.0",
    "vitepress": "^1.6.4",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "animejs": "^4.4.1",
    "particles.js": "^2.0.0",
    "simple-notify": "^1.0.6"
  }
}
